set_global_assignment -name FAMILY "Cyclone V"
set_global_assignment -name DEVICE 5CEBA4F23C7
set_global_assignment -name TOP_LEVEL_ENTITY mips_word_toplevel
set_global_assignment -name ORIGINAL_QUARTUS_VERSION 23.1STD.1
set_global_assignment -name PROJECT_CREATION_TIME_DATE "11:27:59  APRIL 30, 2026"
set_global_assignment -name LAST_QUARTUS_VERSION "23.1std.1 Lite Edition"
set_global_assignment -name VHDL_FILE src/zero_extender.vhd
set_global_assignment -name VHDL_FILE src/ula_numeric.vhd
set_global_assignment -name VHDL_FILE src/ula_fullAdder.vhd
set_global_assignment -name VHDL_FILE src/ula_logicUnit.vhd
set_global_assignment -name VHDL_FILE src/ula_1bit.vhd
set_global_assignment -name VHDL_FILE src/ula_32bits.vhd
set_global_assignment -name VHDL_FILE src/ula_flags.vhd
set_global_assignment -name VHDL_FILE src/ula.vhd
set_global_assignment -name VHDL_FILE src/toplevel_ula.vhd
set_global_assignment -name VHDL_FILE src/toplevel_mips.vhd
set_global_assignment -name VHDL_FILE src/sign_extender.vhd
set_global_assignment -name VHDL_FILE src/reg_file_mips.vhd
set_global_assignment -name VHDL_FILE src/reg_file.vhd
set_global_assignment -name VHDL_FILE src/mips_word_toplevel.vhd
set_global_assignment -name VHDL_FILE src/mips_rom.vhd
set_global_assignment -name VHDL_FILE src/mips_ram.vhd
set_global_assignment -name VHDL_FILE src/demux.vhd
set_global_assignment -name VHDL_FILE src/arith_machine.vhd
set_global_assignment -name PROJECT_OUTPUT_DIRECTORY output_files
set_global_assignment -name ERROR_CHECK_FREQUENCY_DIVISOR 256
set_global_assignment -name MIN_CORE_JUNCTION_TEMP 0
set_global_assignment -name MAX_CORE_JUNCTION_TEMP 85
set_global_assignment -name PARTITION_NETLIST_TYPE SOURCE -section_id Top
set_global_assignment -name PARTITION_FITTER_PRESERVATION_LEVEL PLACEMENT_AND_ROUTING -section_id Top
set_global_assignment -name PARTITION_COLOR 16764057 -section_id Top
set_instance_assignment -name PARTITION_HIERARCHY root_partition -to | -section_id Top

# ---- Pin Assignments: DE10-Standard ----

# Clock 50 MHz
set_location_assignment PIN_AF14 -to clk

# Reset: SW[0] (ativo em '1' quando chave para cima)
set_location_assignment PIN_AB12 -to reset

# LEDs vermelhos LEDR[9:0] - mostram PC[11:2]
set_location_assignment PIN_AA24 -to ledr[0]
set_location_assignment PIN_AB23 -to ledr[1]
set_location_assignment PIN_AC23 -to ledr[2]
set_location_assignment PIN_AD24 -to ledr[3]
set_location_assignment PIN_AG25 -to ledr[4]
set_location_assignment PIN_AF25 -to ledr[5]
set_location_assignment PIN_AE24 -to ledr[6]
set_location_assignment PIN_AF24 -to ledr[7]
set_location_assignment PIN_AG23 -to ledr[8]
set_location_assignment PIN_AF23 -to ledr[9]

# HEX0 (7-seg, ativo baixo) - nibble baixo do PC
set_location_assignment PIN_AE26 -to hex0[0]
set_location_assignment PIN_AE27 -to hex0[1]
set_location_assignment PIN_AE28 -to hex0[2]
set_location_assignment PIN_AG27 -to hex0[3]
set_location_assignment PIN_AF28 -to hex0[4]
set_location_assignment PIN_AG28 -to hex0[5]
set_location_assignment PIN_AH28 -to hex0[6]

# HEX1 (7-seg, ativo baixo) - nibble alto do PC
set_location_assignment PIN_AJ29 -to hex1[0]
set_location_assignment PIN_AH29 -to hex1[1]
set_location_assignment PIN_AH30 -to hex1[2]
set_location_assignment PIN_AG30 -to hex1[3]
set_location_assignment PIN_AF29 -to hex1[4]
set_location_assignment PIN_AF30 -to hex1[5]
set_location_assignment PIN_AD27 -to hex1[6]